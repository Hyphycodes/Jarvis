# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — optional. If missing, the curation brain falls back to
# deterministic picks. The build still passes either way.
ANTHROPIC_API_KEY=

# OpenAI — powers realtime voice transcription and semantic memory embeddings.
# text-embedding-3-small is used for memory retrieval; no new key needed if
# the realtime voice route is already enabled.
OPENAI_API_KEY=

# Cron / background jobs (optional)
CRON_SECRET=

# ElevenLabs — voice intake (Phase 5). Optional; voice features are disabled
# if missing. Use eleven_turbo_v2_5 model for lowest latency.
# Recommended voice: "Daniel" (ID below) — calm, masculine, unhurried. Not
# robotic, not hype. Fits private chief-of-staff energy.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=onwK4e9ZLuTAKqWW03F9

# Site (optional)
NEXT_PUBLIC_SITE_URL=

# Sources — all optional. Adapters whose keys are missing simply
# don't run; downstream callers probe hasX() first.
GOOGLE_PLACES_API_KEY=
MAPBOX_ACCESS_TOKEN=
TICKETMASTER_API_KEY=
TAVILY_API_KEY=
BRAVE_API_KEY=
SERPAPI_KEY=

# Default location used by source queries when no other location is
# resolved (Today hero, Radar refresh, etc.). Falls back to Chicago.
DEFAULT_HOME_LAT=
DEFAULT_HOME_LNG=
DEFAULT_CITY=
DEFAULT_STATE=

# MLB Stats API team id (optional). Defaults to White Sox = 145.
WHITE_SOX_TEAM_ID=145

# Web Push (optional). Powers ambient notifications (Evening Active Mode).
# When any are missing, push is a silent no-op — nothing breaks.
# Generate the key pair with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact email for the push service (mailto: is added automatically if omitted).
VAPID_EMAIL=
# Same value as VAPID_PUBLIC_KEY — exposed to the client for subscribe().
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
